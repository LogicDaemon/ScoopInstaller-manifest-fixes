            "hash": "39a3dee9dc22c66c946f3d04c5d347e5a8cad7b056999d07bf632109616b8203"
        },
        "arm64": {
            "url": "https://downloads.cursor.com/production/80b138a7a0a948e1a798e9ed7867d76a1ba9a318/win32/arm64/user-setup/CursorUserSetup-arm64-3.3.27.exe",
