        "url": "https://www.cursor.com/terms-of-service"
    },
    "innosetup": true,
    "architecture": {
        "64bit": {
            "url": "https://downloads.cursor.com/production/dacbe9b31599a253763e4910eb6ab3870465332c/win32/x64/user-setup/CursorUserSetup-x64-3.1.10.exe",
            "hash": "86b437e2d12a9466c7b7c4c9f3738b6c76ee5b97ba4d69e8842143e3c79b5d50"
        },
        "arm64": {
            "url": "https://downloads.cursor.com/production/dacbe9b31599a253763e4910eb6ab3870465332c/win32/arm64/user-setup/CursorUserSetup-arm64-3.1.10.exe",
            "hash": "be6e3a76c98303b6878f4fcaf6c5206703c10445fd53985b58efe53c8c22aea0"
        }
    },
    "extract_dir": "{code_GetDestDir}",
    "pre_uninstall": [
        "foreach ($p in @(\"$env:USERPROFILE\\.cursor\", \"$env:APPDATA\\Cursor\")) {",
        "    Get-Item $p -ErrorAction SilentlyContinue | Where-Object { $_.Attributes -match 'ReparsePoint' } | Remove-Item -Recurse -Force",
        "}"
    ],
    "post_install": [
        "Remove-item \"$dir\\`$*\", \"$dir\\Uninst*\" -Recurse",
        "if (!(Test-Path \"$persist_dir\\user-data\")) { New-Item -Path \"$persist_dir\\user-data\" -ItemType Directory }",
        "if (!(Test-Path \"$persist_dir\\.cursor\")) { New-Item -Path \"$persist_dir\\.cursor\" -ItemType Directory }",
        "$appDataCursor = \"$env:APPDATA\\Cursor\"",
        "Get-Item $appDataCursor -ErrorAction SilentlyContinue | Where-Object { $_.Attributes -match 'ReparsePoint' } | Remove-Item -Recurse -Force",
        "New-Item -Path $appDataCursor -ItemType Junction -Target \"$persist_dir\\user-data\"",
        "$profileCursor = \"$env:USERPROFILE\\.cursor\"",
        "Get-Item $profileCursor -ErrorAction SilentlyContinue | Where-Object { $_.Attributes -match 'ReparsePoint' } | Remove-Item -Recurse -Force",
        "New-Item -Path $profileCursor -ItemType Junction -Target \"$persist_dir\\.cursor\""
    ],
    "bin": "resources\\app\\bin\\cursor.cmd",
    "shortcuts": [
        [
            "Cursor.exe",
            "Cursor"
        ]
    ],
    "checkver": {
        "url": "https://api2.cursor.sh/updates/api/update/win32-x64-archive/cursor/1.6.35/0572fe0a21dab6fb5784e7787ac8e4640406a769a0c6d6df59509a4d0b380e27/stable",
        "regex": "\"version\":\"([\\d.]+)\".*?/production/(?<Code>[a-f\\d]+)/",
        "useragent": "Cursor/1.6.35"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.cursor.com/production/$matchCode/win32/x64/user-setup/CursorUserSetup-x64-$version.exe"
            },
            "arm64": {
                "url": "https://downloads.cursor.com/production/$matchCode/win32/arm64/user-setup/CursorUserSetup-arm64-$version.exe"
            }
        }
    }
}
